# Copia este archivo a .env solo si quieres cambiar la configuración por defecto.
#
# CASO 1 (por defecto, sin .env): usa el Postgres local de Docker. No hace falta nada.
#
# CASO 2: usar tu Supabase real. Descomenta y completa con tu cadena de conexión
# (Settings > Database > Connection string > Session pooler, puerto 5432). Si la
# contraseña tiene símbolos como @, escríbelos codificados (@ = %40).
# Recomendado: deja DB_SCHEMA vacío para usar "public" (es lo más confiable a
# través del pooler de Supabase). Usa DB_SCHEMA solo con conexión directa.
#
# DATABASE_URL=postgresql+psycopg2://postgres.TU_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# DB_SCHEMA=

# Autenticación con JWT (puedes dejarlo así para el taller)
JWT_SECRET=cambia-esta-clave-super-secreta-en-produccion
JWT_ALG=HS256
JWT_EXP_MINUTES=120

# Caché-aside del dashboard
CACHE_TTL_SECONDS=60

# Tamaño de los datos de prueba (ver seed.py)
SEED_DEMO_IDEAS=50
SEED_USERS=30
SEED_IDEAS_PER_USER=40
